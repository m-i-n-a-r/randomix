<resources>

    <!-- Values for the dark theme -->
    <style name="AppTheme" parent="AppTheme.Base" />

    <style name="AppTheme.Base" parent="Theme.Material3Expressive.DayNight.NoActionBar">
        <item name="android:windowLightStatusBar">false</item>
        <item name="colorPrimary">@color/colorAccent</item>
        <item name="colorPrimaryContainer">@color/colorAccentTranslucent</item>
        <item name="colorSecondary">@color/colorAccent</item>
        <item name="colorOutline">@color/goodGray</item>
        <item name="colorSurfaceVariant">@color/goodGrayTranslucent</item>
        <!-- Navbar item halo -->
        <item name="colorSecondaryContainer">@color/colorAccentTranslucent</item>
        <item name="colorTertiary">@color/colorAccent</item>
        <item name="colorTertiaryContainer">@color/colorAccentTranslucent</item>
        <item name="android:navigationBarColor">@color/colorPrimaryInverse</item>
        <item name="android:statusBarColor">@color/colorBackgroundInverse</item>
        <item name="android:colorBackground">@color/colorBackgroundInverse</item>
        <item name="colorOnPrimary">@color/colorBackgroundInverse</item>
        <item name="android:textColorPrimary">@color/textColorPrimaryInverse</item>
        <item name="android:textColorSecondary">@color/textColorSecondaryInverse</item>
        <item name="android:textColorTertiary">@color/textColorSecondaryInverse</item>
        <item name="bottomSheetDialogTheme">@style/CustomBottomSheetDialog</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.App.MaterialAlertDialog</item>
        <item name="alertDialogTheme">@style/ThemeOverlay.App.MaterialAlertDialog</item>
        <item name="bottomNavigationStyle">@style/CustomBottomNavigation</item>
        <item name="colorOutlineVariant">?attr/colorSurfaceVariant</item>
        <item name="colorOnSecondary">@color/textColorPrimary</item>
        <item name="colorOnSurfaceVariant">@color/textColorPrimaryInverse</item>
        <item name="colorOnBackground">@color/textColorSecondaryInverse</item>
        <item name="materialSwitchStyle">@style/CustomMaterialSwitch</item>
        <item name="colorSurface">@color/almostBlack</item>
        <item name="colorOnSurface">@color/textColorPrimaryInverse</item>
        <item name="android:dialogPreferenceStyle">@style/ThemeOverlay.App.PreferenceDialog.Monet
        </item>
    </style>

    <!-- Monet theme -->
    <style name="AppTheme.Monet" parent="Theme.Material3Expressive.DynamicColors.DayNight">
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="bottomSheetDialogTheme">@style/CustomBottomSheetDialogMonet</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.App.MaterialAlertDialog.Monet
        </item>
        <item name="alertDialogTheme">@style/ThemeOverlay.App.MaterialAlertDialog.Monet</item>
        <item name="windowNoTitle">true</item>
        <item name="switchStyle">@style/Widget.Material3.CompoundButton.MaterialSwitch</item>
        <item name="android:navigationBarColor">?attr/colorSurface</item>
    </style>

    <!-- Switch for amoled theme -->
    <style name="ThemeOverlay.App.Switch" parent="">
        <item name="colorSurfaceVariant">@android:color/black</item>
        <item name="colorOnPrimary">@android:color/black</item>
    </style>

    <style name="CustomMaterialAmoledSwitch" parent="Widget.Material3.CompoundButton.MaterialSwitch">
        <item name="materialThemeOverlay">@style/ThemeOverlay.App.Switch</item>
    </style>

    <style name="CustomBottomAppBarAmoled" parent="Widget.Material3.BottomAppBar">
        <item name="colorSurface">@android:color/black</item>
    </style>

    <!-- Black themes, one for each accent, sadly -->
    <style name="AppTheme.Monet.PerfectDark" parent="AppTheme.Monet">
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:colorBackground">@android:color/black</item>
        <item name="colorSurface">@android:color/black</item>
        <item name="colorSurfaceVariant">@android:color/black</item>
        <item name="colorContainer">@android:color/black</item>
