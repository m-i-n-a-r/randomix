        <item name="colorBackgroundFloating">@android:color/black</item>
        <item name="bottomAppBarStyle">@style/CustomBottomAppBarAmoled</item>
        <item name="materialSwitchStyle">@style/CustomMaterialAmoledSwitch</item>
        <item name="colorSurfaceContainerHigh">@android:color/black</item>
